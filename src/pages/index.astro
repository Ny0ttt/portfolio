---
import "../styles/index.css";

import { getCollection } from "astro:content";
import { name, openGraph } from "spectre:globals";
import ProfilePicture from "../assets/pfp.png";
import Card from "../components/Card.astro";
import Icon from "../components/Icon.astro";
import ImageGlow from "../components/ImageGlow.astro";
import Layout from "../layouts/Layout.astro";
import { base } from "../utils/url";

const [projects, quickInfo, socials] = await Promise.all([
	getCollection("projects"),
	getCollection("quickInfo"),
	getCollection("socials"),
]);

const featuredIds = ["smart-lab", "cleo"];
const featuredProjects = projects
	.filter((p) => featuredIds.includes(p.id))
	.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const otherProjects = projects
	.filter((p) => !featuredIds.includes(p.id))
	.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<Layout
	title={openGraph.home.title || name}
	description={openGraph.home.description}
	pagefindIgnore
>
	<div class="layout-grid-left" slot="left">
		<Card class="flex-col-card">
			<ImageGlow
				quality={100}
				width={120}
				height={120}
				src={ProfilePicture}
				alt="Profile picture"
				loading="eager"
			/>
			<h2>{name}</h2>
			<ul class="overview-list">
				{
					quickInfo.map((info) => (
						<li>
							<Icon
								type={info.data.icon.type}
								name={info.data.icon.name as any}
								width={24}
								height={24}
								class="glow-icon"
							/>
							<span>{info.data.text}</span>
						</li>
					))
				}
			</ul>
		</Card>
		<Card>
			<h3 class="no-mt">Socials</h3>
			<ul class="overview-list">
				{
					socials.map((item) => (
						<li>
							<a href={item.data.link} class="socials-link">
								<Icon
									type={item.data.icon.type}
									name={item.data.icon.name as any}
									width={24}
									height={24}
									class="glow-icon"
								/>
								<span>{item.data.text}</span>
							</a>
						</li>
					))
				}
			</ul>
		</Card>
	</div>

	<div class="layout-grid-right" slot="right">
		<!-- Hero -->
		<Card class="hero-card">
			<p class="hero-label">Open to opportunities</p>
			<h1 class="hero-heading">
				From requirements to production — <span class="text-glow">full-stack, end to end.</span>
			</h1>
			<p class="hero-sub">
				Full-stack engineer shipping across web and mobile — Laravel, Flutter, .NET,
				Vue, React. I work on real products that solve real problems.
			</p>
		</Card>

		<!-- Featured Projects -->
		<div>
			<div class="header-container">
				<Icon
					type="lucide"
					name="star"
					width={20}
					height={20}
					class="glow-icon"
				/>
				<h2 class="no-mt">Featured Projects</h2>
			</div>
			<div class="featured-projects-grid">
				{
					featuredProjects.map((project) => (
						<a href={`${base}projects/${project.id}`} class="featured-project-card">
							<h3 class="featured-project-title">{project.data.title}</h3>
							<p class="featured-project-desc">{project.data.description}</p>
							<div class="project-info-list">
								{project.data.info.map((item) => (
									<span class="project-info-badge">
										<Icon
											type={item.icon.type}
											name={item.icon.name as any}
											width={13}
											height={13}
										/>
										{item.text}
									</span>
								))}
							</div>
							<span class="project-link-hint">View project →</span>
						</a>
					))
				}
			</div>
		</div>

		<!-- Other Projects -->
		<div>
			<div class="header-container">
				<Icon
					type="lucide"
					name="folder-git"
					width={20}
					height={20}
					class="glow-icon"
				/>
				<h2 class="no-mt">Other Projects</h2>
			</div>
			<div class="other-projects-list">
				{
					otherProjects.map((project) => (
						<a href={`${base}projects/${project.id}`} class="other-project-item">
							<div class="other-project-main">
								<h3 class="other-project-title">{project.data.title}</h3>
								<p class="other-project-desc">{project.data.description}</p>
							</div>
							<span class="stack-badge">{project.data.info[0]?.text}</span>
						</a>
					))
				}
			</div>
		</div>

		<!-- Dev Methodologies -->
		<div>
			<div class="header-container">
				<Icon
					type="lucide"
					name="git-branch"
					width={20}
					height={20}
					class="glow-icon"
				/>
				<h2 class="no-mt">How I Work</h2>
			</div>
			<div class="methodologies-grid">
				<Card>
					<h3 class="methodology-title">Prototype-First</h3>
					<div class="methodology-steps">
						<span>Requirements</span>
						<span class="step-arrow">→</span>
						<span>Build Prototype</span>
						<span class="step-arrow">→</span>
						<span>Iterate</span>
						<span class="step-arrow">→</span>
						<span>Push</span>
					</div>
					<p class="methodology-desc">
						Best when the problem is still being discovered. Fast feedback loops,
						frequent pivots, ships early.
					</p>
				</Card>
				<Card>
					<h3 class="methodology-title">Waterfall</h3>
					<div class="methodology-steps">
						<span>Requirements</span>
						<span class="step-arrow">→</span>
						<span>Confirm</span>
						<span class="step-arrow">→</span>
						<span>Build</span>
						<span class="step-arrow">→</span>
						<span>Publish</span>
					</div>
					<p class="methodology-desc">
						Best for clear, stable requirements. Structured delivery, predictable
						milestones, fewer surprises.
					</p>
				</Card>
			</div>
		</div>

		<!-- Testimonials -->
		<!--
		<div>
			<div class="header-container">
				<Icon
					type="lucide"
					name="quote"
					width={20}
					height={20}
					class="glow-icon"
				/>
				<h2 class="no-mt">Testimonials</h2>
			</div>
			<div class="testimonials-grid">
				<Card class="testimonial-card">
					<p class="testimonial-quote">
						"Placeholder testimonial — great to work with, delivered on time and
						above expectations."
					</p>
					<span class="testimonial-author">— Name, Role @ Company</span>
				</Card>
				<Card class="testimonial-card">
					<p class="testimonial-quote">
						"Another placeholder — solid engineer, clear communicator, real
						results."
					</p>
					<span class="testimonial-author">— Name, Role @ Company</span>
				</Card>
			</div>
		</div>
		-->
	</div>
</Layout>
